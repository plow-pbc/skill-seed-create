# macOS
.DS_Store

# Harden-loop working scratch — created if the skill is run in-place.
# Per the seed-create doctrine these logs are ephemeral; the durable record
# is git history. Never committed.
harden-*-log.md

# Eval run records are runtime OUTPUTS (target clone, node_modules, build/test
# logs, baseline.json, fidelity.json). Reproducible by re-running the harness;
# never source. The dir itself is kept via .gitkeep.
eval/runs/*
!eval/runs/.gitkeep

# ============================================================================
# Eval data is kept LOCAL while the targets are still being fleshed out — the
# ENTIRE evals/ tree is gitignored (sources, runs, oracle, definitions,
# screenshots, calibration — everything). The committed framework is the CODE
# (framework/) + docs; the eval *definitions* land later, on their own.
# To start committing eval definitions, narrow this to the specific outputs
# (runs/, source/, .setup/, tests-locked/, …) instead of the whole dir.
# ============================================================================
eval/evals/

# --- dampe-LANE files are dampe-SPECIFIC (local, like all dampe) — NOT part of the
#     generic framework engine, so kept local (eng-macos owns them). STRUCTURAL
#     FOLLOW-UP: these belong under evals/dampe/, not framework/ — move in a later
#     cleanup. The generic macos runner does not import any of them. ---
eval/framework/*dampe*
eval/framework/visual-judge.sh
